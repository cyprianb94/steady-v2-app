{
  "name": "@steady/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./src/contracts.ts",
      "default": "./dist/contracts.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@steady/types": "*",
    "fastify": "^5.1.0",
    "@trpc/server": "^11.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "node-cron": "^3.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "@electric-sql/pglite": "^0.2.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11"
  }
}
