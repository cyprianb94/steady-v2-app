{
  "expo": {
    "name": "Steady",
    "slug": "steady",
    "scheme": "steady",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4EFE6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cyprianbrytan.steady",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F4EFE6",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.cyprianbrytan.steady"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c313c43e-cf2d-4b8e-afaf-081fce0038fb"
      }
    },
    "owner": "cyprianbrytan",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c313c43e-cf2d-4b8e-afaf-081fce0038fb"
    }
  }
}
